;***************************************************
;** Programm, um rueckwaerts aus der Form bis vor **
;***        Teileaufnahme zu fahren              ***
;***************************************************

DEF  RRaus ( )
   
   INT i
   
   B_Ausschuss=TRUE
   $ov_pro=10
   BAS (#vel_cp,1.0)
   BAS (#vel_ptp,50)
   
   ventile_aus ()
   
   $BASE=Base_Data[1]
   $TOOL=Tool_Data[1]
   
   wait for (E_SGM_Form_auf==TRUE) ; $IN[3] SGM Form offen (E67)
   if ($flag[7]==TRUE) then
      LIN  XP100
   endif
   
   if ($flag[6]==TRUE) then
      LIN  XP40
   endif
   
   if ($flag[5]==TRUE) then
      LIN  XP35
   endif
   
   if ($flag[4]==TRUE) then
      LIN  XP30
   endif
   
   if ($flag[3]==TRUE) then
      PTP XP20
   endif
   
   if ($flag[2]==TRUE) then
      PTP XP10
   endif
   
   if ($flag[1]==TRUE) then
      PTP XHome
   else
      Meldung (#notify,10)
      Meldung (#quit,27) 
      loop
         HALT  ;Roboter von Hand aus der Form fahren !!!
      endloop
   endif
   
   for i=1 to 10
      $flag[i]=FALSE
   endfor
   
   B_GST_war_gedrueckt=FALSE
   ;B_L_Start=FALSE
   B_Teilaufnahme=TRUE
   
END

;***************************************************
;** Programm, zum Uberpruefen der Endlagen der   **
;***            Benutzerventile                  ***
;***************************************************

Def Chk_BV (BV_Nr: in,BV_Zustand: in)
   
   INT BV_Nr
   DECL Mode2 BV_Zustand
   
   ;fold  Greiferbelegung, Stand: 02.11.2020
      ;***************************************************
      ;  V1  = Teilevakuum vorne
      ;  V2  = n.v.
      ;  V3  = Teilevakuum vorne unten ;nur ab Umgreifstation
      ;  V4  = Teilevakuum hinten unten ;nur ab Umgreifstation
      ;  BV1/AS = Teilegreifer schließen
      ;  BV1/GS = n.v.
      ;  BV2/AS = Teilegreifer hinten langer hub nach vorne
      ;  BV2/GS = Teilegreifer hinten langer hub nach hinten
      ;  BV3/AS = Teilegreifer hinten kurzer hub nach vorne
      ;  BV3/GS = Teilegreifer hinten kurzer hub nach hinten
      ;  BV4/AS = Angussgreifer schließen
      ;  BV4/GS = n.v.
      ;  BV5/AS = Angussschneider nach vorne
      ;  BV5/GS = Angussschneider nach hinten
      ;  BV6/AS = Angussschneider schließen
      ;***************************************************
   ;endfold
   
   switch BV_Nr
      
      ; Benutzerventil 1 = Teilegreifer
      case 1
         
         switch BV_Zustand
            
            case #GS
               
            case #AS
               
               wait for (E_ASi_22_3==TRUE); IN 363(Abf. Radl oben links)
               wait for (E_ASi_22_4==TRUE); IN 364(Abf. Dreilaendereck links)
               wait for (E_ASi_24_3==TRUE); IN 379(Abf. Radl unten links)  
               wait for (E_ASi_26_3==TRUE); IN 395(Abf. Radl oben rechts)  
               wait for (E_ASi_26_4==TRUE); IN 496(Abf. Dreilaendereck rechts)               
               wait for (E_ASi_28_3==TRUE); IN 411(Abf. Radlauf unten rechts)
               
         endswitch
         
         ; Benutzerventil 2 =  Teilegreifer hinten langer hub
      case 2
         
         switch BV_Zustand
            
            case #GS
               
               wait for (E_ASi_22_1==TRUE)
               wait for (E_ASi_24_1==TRUE)
               wait for (E_ASi_26_1==TRUE)
               wait for (E_ASi_28_1==TRUE)
               
            case #AS
               
               wait for (E_ASi_22_2==TRUE)
               wait for (E_ASi_24_2==TRUE)
               wait for (E_ASi_26_2==TRUE)
               wait for (E_ASi_28_2==TRUE)               
               
         endswitch
         
         ; Benutzerventil 3 = none
      case 3
         
         switch BV_Zustand
            
            case #GS
               
            case #AS
               
         endswitch
         
         ; Benutzerventil 4 = Angussgreifer
      case 4
         
         switch BV_Zustand
            
            case #GS
               
            case #AS
               
               wait for (E_ASi_23_1==TRUE); IN 369(Anguss links)
               wait for (E_ASi_23_2==TRUE); IN 370(Anguss rechts)
               wait for (E_ASi_27_1==TRUE); IN 401(Anguss rechts)
               
         endswitch
         
         ; Benutzerventil 5 = none
      case 5
         
         switch BV_Zustand
            
            case #GS
               
            case #AS
               
         endswitch
         
         ; Benutzerventil 6 = none
      case 6
         
         switch BV_Zustand
            
            case #GS
               
            case #AS
               
         endswitch
         
      default
         loop
            halt ; BV nicht vorhanden
         endloop
         
   endswitch
   
end

;***************************************************
;*** Teileabfrage Vakuumkreise und ASI Eingänge  ***
;***************************************************

DEF Teileabfrage()
   
   wait for (E_VK1==TRUE) 
   ;wait for (E_VK2==TRUE) 
