      SPTP XP1010 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1010), $BASE = SBASE(FP1010.BASE_NO), $IPO_MODE = SIPO_MODE(FP1010.IPO_FRAME), $LOAD = SLOAD(FP1010.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT74), $APO = SAPO_PTP(PPDAT74), $GEAR_JERK[1] = SGEAR_JERK(PPDAT74), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   if ((E_mit_Bedrucken==TRUE) and (B_Ausschuss==FALSE)) then ; $IN[1201] mit Bedrucken von SPS
      ; and (E_WAAGE_TEIL_IO)
      
      ;FOLD SPTP P1020 CONT Vel=100 % PDAT75 Tool[1] Base[0] ;%{PE}
         ;FOLD Parameters ;%{h}
            ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1020; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT75; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
         ;ENDFOLD
         SPTP XP1020 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1020), $BASE = SBASE(FP1020.BASE_NO), $IPO_MODE = SIPO_MODE(FP1020.IPO_FRAME), $LOAD = SLOAD(FP1020.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT75), $APO = SAPO_PTP(PPDAT75), $GEAR_JERK[1] = SGEAR_JERK(PPDAT75), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
      ;ENDFOLD
   endif
   
