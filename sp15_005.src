      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P350; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT13; Kuka.VelocityPath=0.5; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP350 WITH $VEL = SVEL_CP(0.5, , LCPDAT13), $TOOL = STOOL2(FP350), $BASE = SBASE(FP350.BASE_NO), $IPO_MODE = SIPO_MODE(FP350.IPO_FRAME), $LOAD = SLOAD(FP350.TOOL_NO), $ACC = SACC_CP(LCPDAT13), $ORI_TYPE = SORI_TYP(LCPDAT13), $APO = SAPO(LCPDAT13), $JERK = SJERK(LCPDAT13), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   A_BV3_GS=FALSE
   A_BV3_AS=TRUE
   wait for (E_ASi_24_1)==TRUE
   wait for (E_ASi_24_2)==FALSE
   wait for (E_ASi_25_1)==TRUE
   wait for (E_ASi_25_2)==FALSE
   
   A_BV4_GS=FALSE
   A_BV4_AS=TRUE
   wait for (E_ASi_24_3)==TRUE
   wait for (E_ASi_24_4)==FALSE
   wait for (E_ASi_25_3)==TRUE
   wait for (E_ASi_25_4)==FALSE
   A_BV3_AS=FALSE
   A_BV3_GS=TRUE
   wait for (E_ASi_24_1)==FALSE
   wait for (E_ASi_24_2)==TRUE
   wait for (E_ASi_25_1)==FALSE
   wait for (E_ASi_25_2)==TRUE
   A_BV6=TRUE
   wait sec 1.0
   A_BV6=FALSE
   wait sec 1.5
   A_BV3_GS=FALSE
   A_BV3_AS=TRUE
   wait for (E_ASi_24_1)==TRUE
   wait for (E_ASi_24_2)==FALSE
   wait for (E_ASi_25_1)==TRUE
   wait for (E_ASi_25_2)==FALSE
   A_BV4_AS=FALSE
   A_BV4_GS=TRUE
   wait for (E_ASi_24_3)==FALSE
   wait for (E_ASi_24_4)==TRUE
   wait for (E_ASi_25_3)==FALSE
   wait for (E_ASi_25_4)==TRUE
   A_BV3_AS=FALSE
   A_BV3_GS=TRUE
   wait for (E_ASi_24_1)==FALSE
   wait for (E_ASi_24_2)==TRUE
   wait for (E_ASi_25_1)==FALSE
   wait for (E_ASi_25_2)==TRUE
   A_BV1_AS=FALSE
   A_BV1_GS=TRUE
   wait sec 0.5
   A_BV6=FALSE
   
   ;FOLD SLIN P340 CONT Vel=0.5 m/s CPDAT14 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P340; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT14; Kuka.VelocityPath=0.5; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP340 WITH $VEL = SVEL_CP(0.5, , LCPDAT14), $TOOL = STOOL2(FP340), $BASE = SBASE(FP340.BASE_NO), $IPO_MODE = SIPO_MODE(FP340.IPO_FRAME), $LOAD = SLOAD(FP340.TOOL_NO), $ACC = SACC_CP(LCPDAT14), $ORI_TYPE = SORI_TYP(LCPDAT14), $APO = SAPO(LCPDAT14), $JERK = SJERK(LCPDAT14), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P330 CONT Vel=50 % PDAT32 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P330; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT32; Kuka.VelocityPtp=50; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP330 WITH $VEL_AXIS[1] = SVEL_JOINT(50.0), $TOOL = STOOL2(FP330), $BASE = SBASE(FP330.BASE_NO), $IPO_MODE = SIPO_MODE(FP330.IPO_FRAME), $LOAD = SLOAD(FP330.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT32), $APO = SAPO_PTP(PPDAT32), $GEAR_JERK[1] = SGEAR_JERK(PPDAT32), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P320 CONT Vel=50 % PDAT33 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P320; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT33; Kuka.VelocityPtp=50; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP320 WITH $VEL_AXIS[1] = SVEL_JOINT(50.0), $TOOL = STOOL2(FP320), $BASE = SBASE(FP320.BASE_NO), $IPO_MODE = SIPO_MODE(FP320.IPO_FRAME), $LOAD = SLOAD(FP320.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT33), $APO = SAPO_PTP(PPDAT33), $GEAR_JERK[1] = SGEAR_JERK(PPDAT33), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P310 CONT Vel=50 % PDAT34 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P310; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT34; Kuka.VelocityPtp=50; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP310 WITH $VEL_AXIS[1] = SVEL_JOINT(50.0), $TOOL = STOOL2(FP310), $BASE = SBASE(FP310.BASE_NO), $IPO_MODE = SIPO_MODE(FP310.IPO_FRAME), $LOAD = SLOAD(FP310.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT34), $APO = SAPO_PTP(PPDAT34), $GEAR_JERK[1] = SGEAR_JERK(PPDAT34), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P300 CONT Vel=50 % PDAT35 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P300; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT35; Kuka.VelocityPtp=50; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP300 WITH $VEL_AXIS[1] = SVEL_JOINT(50.0), $TOOL = STOOL2(FP300), $BASE = SBASE(FP300.BASE_NO), $IPO_MODE = SIPO_MODE(FP300.IPO_FRAME), $LOAD = SLOAD(FP300.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT35), $APO = SAPO_PTP(PPDAT35), $GEAR_JERK[1] = SGEAR_JERK(PPDAT35), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
END

;***************************************************
;******* Programm zum Abwerfen der Anguesse ********
;***************************************************
DEF Anguss_Abwerfen ()
   
   IR_Ov_Pro (I_Geschw_Anguss)
   
   ;B_BT_Kontrolle=FALSE      ;Bauteilüberwachung ausschalten für Vakuumkreise
   
   ;wait for A_ASi_13_2_ZaZyl_GS==TRUE   ;Zangenarm eingeklappt
   
   ;FOLD SPTP P400 CONT Vel=100 % PDAT36 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P400; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT36; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP400 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP400), $BASE = SBASE(FP400.BASE_NO), $IPO_MODE = SIPO_MODE(FP400.IPO_FRAME), $LOAD = SLOAD(FP400.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT36), $APO = SAPO_PTP(PPDAT36), $GEAR_JERK[1] = SGEAR_JERK(PPDAT36), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   IF (B_Ausschuss==FALSE) then     
      trigger when distance=1 delay=-100 do A_BV5_AS=TRUE
      trigger when distance=1 delay=-100 do A_BV5_GS=FALSE
   ENDIF
   
   ;FOLD SPTP P410 CONT Vel=100 % PDAT37 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P410; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT37; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP410 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP410), $BASE = SBASE(FP410.BASE_NO), $IPO_MODE = SIPO_MODE(FP410.IPO_FRAME), $LOAD = SLOAD(FP410.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT37), $APO = SAPO_PTP(PPDAT37), $GEAR_JERK[1] = SGEAR_JERK(PPDAT37), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P450 Vel=100 % PDAT50 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P450; Kuka.BlendingEnabled=FALSE; Kuka.MoveDataPtpName=PDAT50; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP450 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP450), $BASE = SBASE(FP450.BASE_NO), $IPO_MODE = SIPO_MODE(FP450.IPO_FRAME), $LOAD = SLOAD(FP450.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT50), $APO = SAPO_PTP(PPDAT50), $GEAR_JERK[1] = SGEAR_JERK(PPDAT50), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0)
   ;ENDFOLD
   
   A_BV4_AS=FALSE    ;Angussgreifer öffnen
   
   if (B_Ausschuss==FALSE) then
      A_BV6=TRUE        ;Angussschneider schließen
   endif
   
   A_BV4_AS=TRUE        ;Angussgreifer schließen
   wait sec 0.5
   A_BV4_AS=FALSE
   WAIT SEC 2.0
   A_BV4_AS=TRUE
   wait sec 3.0
   
   ;Schneidezangen zurueck
   A_BV5_GS=TRUE
   A_BV5_AS=FALSE
   wait sec 0.1   
   A_BV6=FALSE       ;Angussschneider öffnen
   IF (E_ASi_23_1 ==TRUE) OR (E_ASi_23_2==TRUE) OR (E_ASi_27_1==TRUE) THEN  ;Eingänge BV4
      
      WAIT FOR B_Beschnitt_EIN==TRUE ; Anguss wurde nicht abgeworfen
      ;xxxxxxxRoboter nach unten fahren!!!!!!
      
   ENDIF
   
   WAIT SEC 0.5
   
   A_BV5_GS=TRUE
   A_BV5_AS=FALSE
   
   


   
   ;FOLD SPTP P460 CONT Vel=100 % PDAT79 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P460; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT79; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP460 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP460), $BASE = SBASE(FP460.BASE_NO), $IPO_MODE = SIPO_MODE(FP460.IPO_FRAME), $LOAD = SLOAD(FP460.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT79), $APO = SAPO_PTP(PPDAT79), $GEAR_JERK[1] = SGEAR_JERK(PPDAT79), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   CONTINUE
   if ((E_mit_Bedrucken==TRUE) AND (E_RFID_RECHTS OR E_RFID_LINKS)) AND (B_Ausschuss==FALSE) then
      drucker (#druck)
   endif
   
   ;FOLD SPTP P470 CONT Vel=100 % PDAT80 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P470; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT80; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP470 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP470), $BASE = SBASE(FP470.BASE_NO), $IPO_MODE = SIPO_MODE(FP470.IPO_FRAME), $LOAD = SLOAD(FP470.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT80), $APO = SAPO_PTP(PPDAT80), $GEAR_JERK[1] = SGEAR_JERK(PPDAT80), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
END

;***************************************************
;******* Programm für die Umgreifstation ***********
;***************************************************
DEF Umgreifstation( )
   
   ;trigger when distance=0 delay=0 do Umgreifstation_Greifer(#zu) prio=-1
   ;FOLD SPTP P600 CONT Vel=100 % PDAT45 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P600; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT45; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP600 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP600), $BASE = SBASE(FP600.BASE_NO), $IPO_MODE = SIPO_MODE(FP600.IPO_FRAME), $LOAD = SLOAD(FP600.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT45), $APO = SAPO_PTP(PPDAT45), $GEAR_JERK[1] = SGEAR_JERK(PPDAT45), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   Umgreifstation_HUB (#HUBGESAMT, #AUF)
   Umgreifstation_Vacuum (#VAC1, #AUS)
   Umgreifstation_Vacuum (#VAC2, #AUS)
   
   ;************************************
   ;Waage abnullen
   Waage (#abnullen)   
   ;************************************
   
   ;FOLD SPTP P610 CONT Vel=100 % PDAT46 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P610; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT46; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP610 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP610), $BASE = SBASE(FP610.BASE_NO), $IPO_MODE = SIPO_MODE(FP610.IPO_FRAME), $LOAD = SLOAD(FP610.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT46), $APO = SAPO_PTP(PPDAT46), $GEAR_JERK[1] = SGEAR_JERK(PPDAT46), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P620 CONT Vel=100 % PDAT47 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P620; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT47; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP620 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP620), $BASE = SBASE(FP620.BASE_NO), $IPO_MODE = SIPO_MODE(FP620.IPO_FRAME), $LOAD = SLOAD(FP620.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT47), $APO = SAPO_PTP(PPDAT47), $GEAR_JERK[1] = SGEAR_JERK(PPDAT47), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P630 CONT Vel=100 % PDAT48 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P630; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT48; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP630 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP630), $BASE = SBASE(FP630.BASE_NO), $IPO_MODE = SIPO_MODE(FP630.IPO_FRAME), $LOAD = SLOAD(FP630.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT48), $APO = SAPO_PTP(PPDAT48), $GEAR_JERK[1] = SGEAR_JERK(PPDAT48), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;Position vor Ablage
   
   ;FOLD SPTP P640 CONT Vel=100 % PDAT49 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P640; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT49; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP640 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP640), $BASE = SBASE(FP640.BASE_NO), $IPO_MODE = SIPO_MODE(FP640.IPO_FRAME), $LOAD = SLOAD(FP640.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT49), $APO = SAPO_PTP(PPDAT49), $GEAR_JERK[1] = SGEAR_JERK(PPDAT49), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;************************************
   ;Abfrage ob Waage abgenullt ist
   Waage (#abfrage)   
   ;************************************  
   
   ;Ablageposition auf Umgreifstation
   
   ;FOLD SLIN P650 Vel=0.5 m/s CPDAT17 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=False; Kuka.PointName=P650; Kuka.BlendingEnabled=False; Kuka.MoveDataName=CPDAT17; Kuka.VelocityPath=0.5; Kuka.VelocityFieldEnabled=True; Kuka.ColDetectFieldEnabled=True; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=True; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP650 WITH $VEL = SVEL_CP(0.5, , LCPDAT17), $TOOL = STOOL2(FP650), $BASE = SBASE(FP650.BASE_NO), $IPO_MODE = SIPO_MODE(FP650.IPO_FRAME), $LOAD = SLOAD(FP650.TOOL_NO), $ACC = SACC_CP(LCPDAT17), $ORI_TYPE = SORI_TYP(LCPDAT17), $APO = SAPO(LCPDAT17), $JERK = SJERK(LCPDAT17), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0)
   ;ENDFOLD
   
   wait sec 0.2  
   
   Umgreifstation_HUB (#HUB_75,#zu)
   Umgreifstation_HUB (#HUB_50,#zu)
   Umgreifstation_HUB (#HUB_20,#zu)
   
   Umgreifstation_Vacuum (#VAC1, #EIN)
   Umgreifstation_Vacuum (#VAC2, #EIN)
   
   B_BT_Kontrolle=FALSE
   interrupt off 23
   
   ;zange oeffnen
   A_BV1_AS=FALSE
   A_BV1_GS=TRUE
   
   A_V1_ein=FALSE  
   
   PULSE ( A_V1_abblasen, TRUE, 2 )
   
   ;Hub_GS
   A_BV2_AS=FALSE
   A_BV3_AS=FALSE
   A_BV4_AS=FALSE
   A_BV2_GS=TRUE
   A_BV3_GS=TRUE
   A_BV4_GS=TRUE
   
   pulse (A_V1_abblasen,TRUE,2.0)
   
   wait sec 0.3
   Umgreifstation_HUB (#HUB_75,#auf)    ;Hub für ausfahren wieder aufmachen
   wait sec 2.0
   
   ;FOLD SLIN P640 CONT Vel=0.5 m/s CPDAT18 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P640; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT18; Kuka.VelocityPath=0.5; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP640 WITH $VEL = SVEL_CP(0.5, , LCPDAT18), $TOOL = STOOL2(FP640), $BASE = SBASE(FP640.BASE_NO), $IPO_MODE = SIPO_MODE(FP640.IPO_FRAME), $LOAD = SLOAD(FP640.TOOL_NO), $ACC = SACC_CP(LCPDAT18), $ORI_TYPE = SORI_TYP(LCPDAT18), $APO = SAPO(LCPDAT18), $JERK = SJERK(LCPDAT18), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD WAIT FOR ( IN 305 'HS_VAKUUM_1_EIN' ) CONT;%{PE}%R 8.3.44,%MKUKATPBASIS,%CEXT_WAIT_FOR,%VEXT_WAIT_FOR,%P 2:, 4:, 5:$IN, 6:305, 7:HS_VAKUUM_1_EIN, 9:CONTINUE
      CONTINUE
      WAIT FOR  ( $IN[305] ) 
   ;ENDFOLD
   
   ;FOLD WAIT FOR ( IN 307 'HS_VAKUUM_2_EIN' ) CONT;%{PE}%R 8.3.44,%MKUKATPBASIS,%CEXT_WAIT_FOR,%VEXT_WAIT_FOR,%P 2:, 4:, 5:$IN, 6:307, 7:HS_VAKUUM_2_EIN, 9:CONTINUE
      CONTINUE
      WAIT FOR  ( $IN[307] ) 
   ;ENDFOLD
   
   TRIGGER WHEN DISTANCE = 1 DELAY = 0 DO Umgreifstation_HUB (#HUB_75,#zu) PRIO=1 ;Hub nach ausfahren wieder schließen
   ;FOLD SPTP P630 CONT Vel=100 % PDAT51 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P630; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT51; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP630 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP630), $BASE = SBASE(FP630.BASE_NO), $IPO_MODE = SIPO_MODE(FP630.IPO_FRAME), $LOAD = SLOAD(FP630.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT51), $APO = SAPO_PTP(PPDAT51), $GEAR_JERK[1] = SGEAR_JERK(PPDAT51), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;if ((E_mit_Beflammen==TRUE) and (B_Ausschuss==FALSE)) then ; $IN[1202] mit Beflammen von SPS
   ;  trigger when distance=0 delay=-1500 do Brenner (I_n_aktive_Brenner,#zuenden) prio=-1
   ;endif
   
   ;FOLD SPTP P620 CONT Vel=100 % PDAT52 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P620; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT52; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP620 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP620), $BASE = SBASE(FP620.BASE_NO), $IPO_MODE = SIPO_MODE(FP620.IPO_FRAME), $LOAD = SLOAD(FP620.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT52), $APO = SAPO_PTP(PPDAT52), $GEAR_JERK[1] = SGEAR_JERK(PPDAT52), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD   
   
   ;************************************
   ;Teil wiegen     
   TRIGGER WHEN DISTANCE = 1 DELAY = 0 DO Waage (#wiegen) PRIO = 1
   ;************************************  
   ;FOLD SPTP P610 CONT Vel=100 % PDAT53 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P610; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT53; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP610 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP610), $BASE = SBASE(FP610.BASE_NO), $IPO_MODE = SIPO_MODE(FP610.IPO_FRAME), $LOAD = SLOAD(FP610.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT53), $APO = SAPO_PTP(PPDAT53), $GEAR_JERK[1] = SGEAR_JERK(PPDAT53), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P600 CONT Vel=100 % PDAT54 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P600; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT54; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP600 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP600), $BASE = SBASE(FP600.BASE_NO), $IPO_MODE = SIPO_MODE(FP600.IPO_FRAME), $LOAD = SLOAD(FP600.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT54), $APO = SAPO_PTP(PPDAT54), $GEAR_JERK[1] = SGEAR_JERK(PPDAT54), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;************************************
   ;Warte bis Waage fertig  
   TRIGGER WHEN DISTANCE = 1 DELAY = 0 DO Waage (#warten) PRIO = 1
   ;************************************   
   ;FOLD SPTP P660 CONT Vel=100 % PDAT81 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P660; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT81; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP660 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP660), $BASE = SBASE(FP660.BASE_NO), $IPO_MODE = SIPO_MODE(FP660.IPO_FRAME), $LOAD = SLOAD(FP660.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT81), $APO = SAPO_PTP(PPDAT81), $GEAR_JERK[1] = SGEAR_JERK(PPDAT81), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   CONTINUE
   A_V3_ein=TRUE
   
   CONTINUE
   A_V4_ein=TRUE
   
   ;Aufnahmeposition für Umgreifstation
   
   ;FOLD SLIN P670 Vel=2 m/s CPDAT26 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=False; Kuka.PointName=P670; Kuka.BlendingEnabled=False; Kuka.MoveDataName=CPDAT26; Kuka.VelocityPath=2; Kuka.VelocityFieldEnabled=True; Kuka.ColDetectFieldEnabled=True; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=True; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP670 WITH $VEL = SVEL_CP(2.0, , LCPDAT26), $TOOL = STOOL2(FP670), $BASE = SBASE(FP670.BASE_NO), $IPO_MODE = SIPO_MODE(FP670.IPO_FRAME), $LOAD = SLOAD(FP670.TOOL_NO), $ACC = SACC_CP(LCPDAT26), $ORI_TYPE = SORI_TYP(LCPDAT26), $APO = SAPO(LCPDAT26), $JERK = SJERK(LCPDAT26), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0)
   ;ENDFOLD
   
   wait for E_VK3
   wait for E_VK4
   
   ;Umgreifstation wieder in Grundstellung bringen
   Umgreifstation_Vacuum (#VAC1, #AUS)
   Umgreifstation_Vacuum (#VAC2, #AUS)
   Umgreifstation_HUB (#HUBGESAMT, #AUF)
   
   ;FOLD SLIN P660 CONT Vel=2 m/s CPDAT26 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P660; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT26; Kuka.VelocityPath=2; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP660 WITH $VEL = SVEL_CP(2.0, , LCPDAT26), $TOOL = STOOL2(FP660), $BASE = SBASE(FP660.BASE_NO), $IPO_MODE = SIPO_MODE(FP660.IPO_FRAME), $LOAD = SLOAD(FP660.TOOL_NO), $ACC = SACC_CP(LCPDAT26), $ORI_TYPE = SORI_TYP(LCPDAT26), $APO = SAPO(LCPDAT26), $JERK = SJERK(LCPDAT26), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   CONTINUE
   IF not (E_VK3 AND E_VK4) == TRUE THEN  
      
      wait for E_VK3 AND E_VK4
      
   ENDIF
   
   B_BT_Kontrolle=TRUE
   interrupt on 23
   
END

;***************************************************
;******** Programm zum Bauteilbedrucken ************
;***************************************************

DEF RFID ()
   
   ;FOLD SPTP P800 CONT Vel=100 % PDAT55 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P800; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT55; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP800 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP800), $BASE = SBASE(FP800.BASE_NO), $IPO_MODE = SIPO_MODE(FP800.IPO_FRAME), $LOAD = SLOAD(FP800.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT55), $APO = SAPO_PTP(PPDAT55), $GEAR_JERK[1] = SGEAR_JERK(PPDAT55), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P810 CONT Vel=100 % PDAT56 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P810; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT56; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP810 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP810), $BASE = SBASE(FP810.BASE_NO), $IPO_MODE = SIPO_MODE(FP810.IPO_FRAME), $LOAD = SLOAD(FP810.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT56), $APO = SAPO_PTP(PPDAT56), $GEAR_JERK[1] = SGEAR_JERK(PPDAT56), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   CONTINUE
   IF (E_RFID_Links == TRUE) and (E_mit_Bedrucken==TRUE) and (B_Ausschuss==FALSE) then       ; $IN[1201] mit Bedrucken von SPS, $IN[1369] Etikett Links von SPS
      
      ;FOLD ETIKETT LINKS
         
         trigger when distance=1 delay=0 do drucker(#druck)prio=-1   ;RFID, Teilelabel drucken
         ;FOLD SPTP P820 CONT Vel=100 % PDAT57 Tool[1] Base[0] ;%{PE}
            ;FOLD Parameters ;%{h}
               ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P820; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT57; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
            ;ENDFOLD
            SPTP XP820 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP820), $BASE = SBASE(FP820.BASE_NO), $IPO_MODE = SIPO_MODE(FP820.IPO_FRAME), $LOAD = SLOAD(FP820.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT57), $APO = SAPO_PTP(PPDAT57), $GEAR_JERK[1] = SGEAR_JERK(PPDAT57), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
         ;ENDFOLD
         
         ;FOLD SLIN P830 Vel=2 m/s CPDAT27 Tool[1] Base[0] ;%{PE}
            ;FOLD Parameters ;%{h}
               ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P830; Kuka.BlendingEnabled=FALSE; Kuka.MoveDataName=CPDAT27; Kuka.VelocityPath=2; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
            ;ENDFOLD
            SLIN XP830 WITH $VEL = SVEL_CP(2.0, , LCPDAT27), $TOOL = STOOL2(FP830), $BASE = SBASE(FP830.BASE_NO), $IPO_MODE = SIPO_MODE(FP830.IPO_FRAME), $LOAD = SLOAD(FP830.TOOL_NO), $ACC = SACC_CP(LCPDAT27), $ORI_TYPE = SORI_TYP(LCPDAT27), $APO = SAPO(LCPDAT27), $JERK = SJERK(LCPDAT27), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0)
         ;ENDFOLD
         
         ; RFID-Appl. Position
         wait sec 0.1
         drucker (#appl)
         wait sec 0.1
         
         ;FOLD SLIN P820 CONT Vel=0.5 m/s CPDAT20 Tool[1] Base[0] ;%{PE}
            ;FOLD Parameters ;%{h}
               ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P820; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT20; Kuka.VelocityPath=0.5; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
            ;ENDFOLD
            SLIN XP820 WITH $VEL = SVEL_CP(0.5, , LCPDAT20), $TOOL = STOOL2(FP820), $BASE = SBASE(FP820.BASE_NO), $IPO_MODE = SIPO_MODE(FP820.IPO_FRAME), $LOAD = SLOAD(FP820.TOOL_NO), $ACC = SACC_CP(LCPDAT20), $ORI_TYPE = SORI_TYP(LCPDAT20), $APO = SAPO(LCPDAT20), $JERK = SJERK(LCPDAT20), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
         ;ENDFOLD
         
      ;ENDFOLD
      
   ENDIF
   
   ;RFID RECHTS WIRD NICHT VERWENDET
   RETURN
   
   CONTINUE
   IF (E_RFID_Rechts == TRUE) and (E_mit_Bedrucken == TRUE) and (B_Ausschuss==FALSE) then   ; $IN[1201] mit Bedrucken von SPS, $IN[1370] Etikett Links von SPS
      
      ;FOLD Etikett Rechts
         
         ;Drehung bei 2 Teilen
         
         ;FOLD SPTP P840 CONT Vel=100 % PDAT59 Tool[1] Base[0] ;%{PE}
            ;FOLD Parameters ;%{h}
               ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P840; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT59; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
            ;ENDFOLD
            SPTP XP840 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP840), $BASE = SBASE(FP840.BASE_NO), $IPO_MODE = SIPO_MODE(FP840.IPO_FRAME), $LOAD = SLOAD(FP840.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT59), $APO = SAPO_PTP(PPDAT59), $GEAR_JERK[1] = SGEAR_JERK(PPDAT59), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
         ;ENDFOLD   
         
         trigger when distance=1 delay=0 do drucker(#druck)prio=-1      ;RFID, Teilelabel drucken
         ;FOLD SPTP P850 CONT Vel=100 % PDAT83 Tool[1] Base[0] ;%{PE}
            ;FOLD Parameters ;%{h}
               ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P850; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT83; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
            ;ENDFOLD
            SPTP XP850 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP850), $BASE = SBASE(FP850.BASE_NO), $IPO_MODE = SIPO_MODE(FP850.IPO_FRAME), $LOAD = SLOAD(FP850.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT83), $APO = SAPO_PTP(PPDAT83), $GEAR_JERK[1] = SGEAR_JERK(PPDAT83), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
         ;ENDFOLD
         
         ;FOLD SLIN P860 Vel=0.5 m/s CPDAT28 Tool[1] Base[0] ;%{PE}
            ;FOLD Parameters ;%{h}
               ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P860; Kuka.BlendingEnabled=FALSE; Kuka.MoveDataName=CPDAT28; Kuka.VelocityPath=0.5; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
            ;ENDFOLD
            SLIN XP860 WITH $VEL = SVEL_CP(0.5, , LCPDAT28), $TOOL = STOOL2(FP860), $BASE = SBASE(FP860.BASE_NO), $IPO_MODE = SIPO_MODE(FP860.IPO_FRAME), $LOAD = SLOAD(FP860.TOOL_NO), $ACC = SACC_CP(LCPDAT28), $ORI_TYPE = SORI_TYP(LCPDAT28), $APO = SAPO(LCPDAT28), $JERK = SJERK(LCPDAT28), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0)
         ;ENDFOLD
         
         ; RFID-Appl. Position 2
         wait sec 0.1
         drucker (#appl)
         wait sec 0.1
         
         ;FOLD SLIN P850 CONT Vel=0.5 m/s CPDAT29 Tool[1] Base[0] ;%{PE}
            ;FOLD Parameters ;%{h}
               ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P850; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT29; Kuka.VelocityPath=0.5; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
            ;ENDFOLD
            SLIN XP850 WITH $VEL = SVEL_CP(0.5, , LCPDAT29), $TOOL = STOOL2(FP850), $BASE = SBASE(FP850.BASE_NO), $IPO_MODE = SIPO_MODE(FP850.IPO_FRAME), $LOAD = SLOAD(FP850.TOOL_NO), $ACC = SACC_CP(LCPDAT29), $ORI_TYPE = SORI_TYP(LCPDAT29), $APO = SAPO(LCPDAT29), $JERK = SJERK(LCPDAT29), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
         ;ENDFOLD
         
      ;endfold
      
   ENDIF
   
end

;***************************************************
;****** Programm zum Bauteilbeflammen **************
;***************************************************

DEF Beflammen ()
   
   ;BEFLAMMEN WIRD NICHT VERWENDET
   RETURN
   
   ;FOLD SPTP P700 CONT Vel=100 % PDAT64 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P700; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT64; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP700 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP700), $BASE = SBASE(FP700.BASE_NO), $IPO_MODE = SIPO_MODE(FP700.IPO_FRAME), $LOAD = SLOAD(FP700.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT64), $APO = SAPO_PTP(PPDAT64), $GEAR_JERK[1] = SGEAR_JERK(PPDAT64), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   trigger when distance=1 delay=-100 do Brenner (I_n_aktive_Brenner,#zuenden) prio=-1
   ;FOLD SPTP P710 CONT Vel=100 % PDAT65 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P710; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT65; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP710 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP710), $BASE = SBASE(FP710.BASE_NO), $IPO_MODE = SIPO_MODE(FP710.IPO_FRAME), $LOAD = SLOAD(FP710.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT65), $APO = SAPO_PTP(PPDAT65), $GEAR_JERK[1] = SGEAR_JERK(PPDAT65), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   continue
   if ((E_mit_Bedrucken==TRUE) and (B_Ausschuss==FALSE)) then ; $IN[1201] mit Bedrucken von SPS
      trigger when distance=1 delay=0 do drucker(#druck)prio=-1
   endif ; and (E_WAAGE_TEIL_IO)
   
   ;FOLD SPTP P720 CONT Vel=100 % PDAT66 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P720; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT66; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP720 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP720), $BASE = SBASE(FP720.BASE_NO), $IPO_MODE = SIPO_MODE(FP720.IPO_FRAME), $LOAD = SLOAD(FP720.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT66), $APO = SAPO_PTP(PPDAT66), $GEAR_JERK[1] = SGEAR_JERK(PPDAT66), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   $ov_pro=I_Geschw_Brenner 
   ;trigger when distance=0 delay=0 do B_Brenner_aktiv=TRUE
   ;Brenner (I_n_aktive_Brenner,#waitRdy)
   
   ;FOLD SPTP P730 CONT Vel=100 % PDAT67 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
