;***************************************************
;** Alternativprogramm ohne Bauteilbeflammen *******
;***************************************************

DEF ohne_Beflammen ()
   
   ;BEFLAMMEN WIRD NICHT VERWENDET
   RETURN
   
   ; hier Roboterbewegung
   
   trigger when distance=1 delay=0 do UmgreifStation_Pos (#auf) prio=-1
   ;FOLD SPTP P1000 CONT Vel=100 % PDAT73 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1000; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT73; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1000 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1000), $BASE = SBASE(FP1000.BASE_NO), $IPO_MODE = SIPO_MODE(FP1000.IPO_FRAME), $LOAD = SLOAD(FP1000.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT73), $APO = SAPO_PTP(PPDAT73), $GEAR_JERK[1] = SGEAR_JERK(PPDAT73), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   continue
   if ((E_mit_Bedrucken==TRUE) and (B_Ausschuss==FALSE)) then ; $IN[1201] mit Bedrucken von SPS
      trigger when distance=1 delay=0 do drucker(#druck)prio=-1
      
   endif ; and (E_WAAGE_TEIL_IO)
   
   ;FOLD SPTP P1010 CONT Vel=100 % PDAT74 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1010; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT74; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
