;**************************************************
;Ablegen der i.O. Teile auf Foerderband 1 unten****
;********* Ablage auf Riemen 4-Gurt Band **********
;**************************************************

DEF FB1_Ablage_unten ()
   
   IR_Ov_Pro (I_Geschw_FB)
   
   ;********************************************************************
   ;Bei Verwendung von Umgreifstation sind Einfahrbewegungen nicht nötig
   ;FOLD SPTP P1900 CONT Vel=100 % PDAT18 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1900; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT18; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      ;SPTP XP1900 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1900), $BASE = SBASE(FP1900.BASE_NO), $IPO_MODE = SIPO_MODE(FP1900.IPO_FRAME), $LOAD = SLOAD(FP1900.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT18), $APO = SAPO_PTP(PPDAT18), $GEAR_JERK[1] = SGEAR_JERK(PPDAT18), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   ;FOLD SPTP P1910 CONT Vel=100 % PDAT8 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1910; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT8; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      ;SPTP XP1910 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1910), $BASE = SBASE(FP1910.BASE_NO), $IPO_MODE = SIPO_MODE(FP1910.IPO_FRAME), $LOAD = SLOAD(FP1910.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT8), $APO = SAPO_PTP(PPDAT8), $GEAR_JERK[1] = SGEAR_JERK(PPDAT8), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   ;FOLD SPTP P1920 CONT Vel=100 % PDAT19 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1920; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT19; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      ;SPTP XP1920 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1920), $BASE = SBASE(FP1920.BASE_NO), $IPO_MODE = SIPO_MODE(FP1920.IPO_FRAME), $LOAD = SLOAD(FP1920.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT19), $APO = SAPO_PTP(PPDAT19), $GEAR_JERK[1] = SGEAR_JERK(PPDAT19), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   ;********************************************************************
   
   ;FOLD Bandlaufzeiten an SPS uebergeben
      ;continue
      ;AS_Laufzeit_FB1=R_Laufzeit_FB1*10
      ;continue
      ;AS_Nachlaufzeit_FB1=R_Nachlaufzeit_FB1*10
      ;continue
      ;AS_Laufzeit_FB2=R_Laufzeit_FB2*10
      ;continue
      ;AS_Nachlaufzeit_FB2=R_Nachlaufzeit_FB2*10
   ;ENDFOLD
   
   CONTINUE
   PULSE ( A_Anf_FB1_Bt_ablegen, TRUE, 0.5 ) ;Anfrage zur Teileblage
   
   CONTINUE
   wait for (E_FB1_unten_Ant_ber==TRUE) and (R_Laufzeit_FB1_u_reached==TRUE) ;Arbeitsbereich freigegeben und Laufzeit abgelaufen 
   
   ;FOLD SPTP P1930_unten CONT Vel=100 % PDAT20 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1930_unten; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT20; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1930_unten WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1930_unten), $BASE = SBASE(FP1930_unten.BASE_NO), $IPO_MODE = SIPO_MODE(FP1930_unten.IPO_FRAME), $LOAD = SLOAD(FP1930_unten.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT20), $APO = SAPO_PTP(PPDAT20), $GEAR_JERK[1] = SGEAR_JERK(PPDAT20), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   TRIGGER WHEN DISTANCE = 1 DELAY = 0 DO A_AbFrg_FB1=FALSE ;Arbeitsbereich sperren
   trigger when distance=1 delay=0 do B_BT_Kontrolle=FALSE
   ;FOLD SPTP P1940_unten CONT Vel=100 % PDAT21 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1940_unten; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT21; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1940_unten WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1940_unten), $BASE = SBASE(FP1940_unten.BASE_NO), $IPO_MODE = SIPO_MODE(FP1940_unten.IPO_FRAME), $LOAD = SLOAD(FP1940_unten.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT21), $APO = SAPO_PTP(PPDAT21), $GEAR_JERK[1] = SGEAR_JERK(PPDAT21), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;Ablageposition
   TRIGGER WHEN DISTANCE = 1 DELAY = 0 DO  Ventile_aus () PRIO = 1
   ;FOLD SLIN P1950_unten Vel=1 m/s CPDAT11 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1950_unten; Kuka.BlendingEnabled=FALSE; Kuka.MoveDataName=CPDAT11; Kuka.VelocityPath=1; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP1950_unten WITH $VEL = SVEL_CP(1.0, , LCPDAT11), $TOOL = STOOL2(FP1950_unten), $BASE = SBASE(FP1950_unten.BASE_NO), $IPO_MODE = SIPO_MODE(FP1950_unten.IPO_FRAME), $LOAD = SLOAD(FP1950_unten.TOOL_NO), $ACC = SACC_CP(LCPDAT11), $ORI_TYPE = SORI_TYP(LCPDAT11), $APO = SAPO(LCPDAT11), $JERK = SJERK(LCPDAT11), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0)
   ;ENDFOLD
   
   wait sec 0.5      ;Ablagezeit
   
   B_Abbruch_aktiv=FALSE
   
   TRIGGER WHEN DISTANCE = 1 DELAY = 0 DO PULSE ( A_FB1_Unten_Start, TRUE, 1 )      ;Förderband takten
   trigger when distance=1 delay=0 do A_AbFrg_FB1=TRUE                              ;Arbeitsbereich wieder freigeben
   ;FOLD SLIN P1940_unten CONT Vel=1 m/s CPDAT12 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1940_unten; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT12; Kuka.VelocityPath=1; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP1940_unten WITH $VEL = SVEL_CP(1.0, , LCPDAT12), $TOOL = STOOL2(FP1940_unten), $BASE = SBASE(FP1940_unten.BASE_NO), $IPO_MODE = SIPO_MODE(FP1940_unten.IPO_FRAME), $LOAD = SLOAD(FP1940_unten.TOOL_NO), $ACC = SACC_CP(LCPDAT12), $ORI_TYPE = SORI_TYP(LCPDAT12), $APO = SAPO(LCPDAT12), $JERK = SJERK(LCPDAT12), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ; XP1930 beim Ausfahren nicht nötig 
   ;FOLD SPTP P1930_unten CONT Vel=100 % PDAT22 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1930_unten; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT22; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      ;SPTP XP1930_unten WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1930_unten), $BASE = SBASE(FP1930_unten.BASE_NO), $IPO_MODE = SIPO_MODE(FP1930_unten.IPO_FRAME), $LOAD = SLOAD(FP1930_unten.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT22), $APO = SAPO_PTP(PPDAT22), $GEAR_JERK[1] = SGEAR_JERK(PPDAT22), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P1920 CONT Vel=100 % PDAT23 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1920; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT23; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1920 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1920), $BASE = SBASE(FP1920.BASE_NO), $IPO_MODE = SIPO_MODE(FP1920.IPO_FRAME), $LOAD = SLOAD(FP1920.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT23), $APO = SAPO_PTP(PPDAT23), $GEAR_JERK[1] = SGEAR_JERK(PPDAT23), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
