&ACCESS RVO
&REL 249
&PARAM DISKPATH = KRC:\R1\Program\Bauteilprogramme
DEF  sp15_005 ( )
   
   int i
   ;FOLD INI;%{PE}
      ;FOLD BASISTECH INI
         GLOBAL INTERRUPT DECL 3 WHEN $STOPMESS==TRUE DO IR_STOPM ( )
         INTERRUPT ON 3 
         BAS (#INITMOV,0 )
      ;ENDFOLD (BASISTECH INI)
      ;FOLD USER INI
         ;Make your modifications here
         
      ;ENDFOLD (USER INI)
   ;ENDFOLD (INI)
   
   ;************************************************
   ;  Werkzeug: DAG C238 Verkleidung Oberteil hinten
   ;  Form-Nr.: SP2015_005
   ;  Form-Code: 242
   ;  RFID-Code: 242
   ;  Maschinentyp: DUO 4000
   ;  Roboterposition: hinter Maschine
   ;  Werkzeug offen: 1900 mm
   ;  vorzeitiges Einfahren: nein
   ;  erstellt von: Franz Schmalzl, KUKA R13-Eng, Appl.
   ;  am: 01.08.2012
   ;  geaendert: Kögel Martin (ENGEL Austria)
   ;  am: 25.01.2023, Stand: 1
   ;  LOAD_DATA[1]={M 117.904472,CM {X -52.2514915,Y 10.2545710,Z 301.834,A -90.0127335,B -0.154805,C 88.7983932},J {X 10.1444,Y 18.9007835,Z 24.7496796}}
   ;***************************************************
   
   ;fold  Greiferbelegung, Stand: 25.01.2023
      ;***************************************************
      ;  V1  = Teilevakuum vorne
      ;  V2  = n.v.
      ;  V3  = Teilevakuum vorne unten ;nur ab Umgreifstation
      ;  V4  = Teilevakuum hinten unten ;nur ab Umgreifstation
      ;  BV1/AS = Teilegreifer schließen
      ;  BV1/GS = n.v.
      ;  BV2/AS = Teilegreifer hinten langer hub nach vorne
      ;  BV2/GS = Teilegreifer hinten langer hub nach hinten
      ;  BV3/AS = Teilegreifer hinten kurzer hub nach vorne
      ;  BV3/GS = Teilegreifer hinten kurzer hub nach hinten
      ;  BV4/AS = Angussgreifer schließen
      ;  BV4/GS = n.v.
      ;  BV5/AS = Angussschneider nach vorne
      ;  BV5/GS = Angussschneider nach hinten
      ;  BV6/AS = Angussschneider schließen
      ;***************************************************
   ;endfold
   
   ;FOLD PROGRAMMPARAMETER
      
      ;Fold Geschwindigkeitsvorgaben ($OV_Pro)
         I_Geschw_SGM=30
         I_Geschw_Zange=30
         I_Geschw_FB=30
         I_Geschw_Anguss=30
         I_Geschw_Brenner=30
         I_Geschw_allgemein=30
         R_vel_min_beflammen=0.05 ; Minimale Beflammgeschwindigkeit
      ;Endfold
      
      ;Fold Lastdaten
         ;** Greifer 242 **
         LOAD_DATA[1]={M 117.904472,CM {X -52.2514915,Y 10.2545710,Z 301.834,A -90.0127335,B -0.154805,C 88.7983932},J {X 10.1444,Y 18.9007835,Z 24.7496796}}
      ;Endfold
      
      ;Fold Codes
         
         ;Muss nur bei Inbetriebnahme geaendert werden
         I_Greifercode=242   ;Codenummer fuer Greifer
         I_Formcode=242     ;Codenummer fuer Form
         
         ;***Artikelnummeruebergabe an RFID
         I_Artikelnummer_1=242
         drucker  (#init1)
         ;I_Artikelnummer_2=0
         ;drucker  (#init2)
      ;Endfold Codes
      
      ;Fold Foerderband-Parameter
         ;Start Foerderband
         A_FB1_Oben_Start=TRUE
         A_FB1_Unten_Start=TRUE
         
         ; *** Foerderband 1 = oben ***
         R_Laufzeit_FB1_oben= 5.0 ; Laufzeit fuer Foerderband 1 [ms]
         R_Nachlaufzeit_FB1=2.0 ; Nachlaufzeit FB 1 zur Leererkennung [s]
         
         ; *** Foerderband 1 = unten
         R_Laufzeit_FB1_unten= 5 ; Laufzeit fuer Foerderband 2 [ms]
         R_Nachlaufzeit_FB1=2.0 ; Nachlaufzeit FB 2 zur Leererkennung [s]
      ;Endfold
      
      ;FOLD Brennervorwahl
         ; Bsp: 
         ; nur Brenner 1: 'b001'
         ; nur Brenner 2: 'b010'
         ; nur Brenner 3: 'b100'
         ; Brenner 1 u. 3: 'b101' usw.
         ;I_n_aktive_Brenner='b000'
         ;R_t_max_beflammen=20 ;[s]
      ;ENDFOLD
      
      ;Fold sonstige Parameter
         $timer[1]=0
         $timer[2]=0
         $timer[13]=0
         $timer[14]=0
         B_Zykluszeit1=FALSE
         B_Zykluszeit2=FALSE
      ;Endfold
      
      ;Fold Greifersignale
         I_AnzahlGreifersign=4
      ;Endfold Greifersignale
      
   ;ENDFOLD
   
   ;FOLD Meldungen und Interrupt-Deklarationen
      ;Benutzerdefinierte Hinweismeldungen [1-20]
      MH_Msg[6].MSG_TXT[]="Kein aktives Benutzerventil gewaelht"
      MH_Msg[7].MSG_TXT[]="Keinen aktiven Vakkumkreis gewaehlt "
      MH_Msg[8].MSG_TXT[]="Keine aktive Zangenposition gewaehlt "
      MH_Msg[9].MSG_TXT[]="Keinen aktiven Wert gewaehlt "
      MH_Msg[10].MSG_TXT[]="Kein Merkerflag fuer Rueckwaerts rausfahren gesetzt!"
      
      ;Benutzerdefinierte Quittierungsmeldungen [21-40]
      MH_Msg[21].MSG_TXT[]="Achtung, eventuell vorhandenes Bauteil wird abgeworfen!!! "
      MH_Msg[26].MSG_TXT[]="Bauteilprogramm direkt angewaehlt, bitte Hauptprogramm anwaehlen!!!"
      MH_Msg[27].MSG_TXT[]="Roboter im Testbetrieb freifahren!!!"
      MH_Msg[28].MSG_TXT[]=" "
      MH_Msg[29].MSG_TXT[]=" "
      MH_Msg[30].MSG_TXT[]=" "
      
      $cycflag[1]=B_BT_Kontrolle and ((E_VK1 exor A_V1_ein) or (E_VK2 exor A_V2_ein) or (E_VK3 exor A_V3_ein) or (E_VK4 exor A_V4_ein))
      $cycflag[2]=B_T_GRUND or not E_SGM_AUTO or (B_Abbruch_aktiv and B_T_Abbruch)
      $cycflag[5]=E_MPS125_gekoppelt and not E_MPS125_entriegelt and E_MPS125_verriegelt
      
      interrupt decl 20 when  not B_Teilaufnahme and B_GST_war_gedrueckt do INT_AbbruchEinfahrtSGM ( )
      interrupt decl 21 when not E_SGM_Form_auf and B_Reinf DO INT_stop_IR ( )
      interrupt decl 22 when not E_GZBG_aus AND not B_Fangaktiv do  Int_GZBG ( )
      interrupt decl 23 when $cycflag[1] do INT_BtKontrolle ( )
      interrupt decl 24 when $cycflag[2] do INT_GS ( )
      interrupt decl 28 when $cycflag[5]==FALSE do INT_mps125_gekuppelt ( )
      
      interrupt off 20
      interrupt off 21
      interrupt off 22
      interrupt off 23
      interrupt off 24
      
   ;Endfold (Meldungen und Interrupt)
   
   ;FOLD Programm directly selected
      
      WHILE (B_aus_Haupt==FALSE)
         Meldung(#quit,26)
         HALT
      ENDWHILE
      
   ;ENDFOLD
   


   repeat
      
      $advance=5
      
      SGM_reset()
      Meldung (#quit,21) 
      Ventile_aus()
      
      for i=1 to  50 
         $flag[i]=FALSE
      endfor
      
      B_GST_war_gedrueckt=FALSE;Merker fuer Grundstellungstaste
      $timer[14]=0             ;FB Timer zuruecksetzen
      $timer[1]=0              ;Zyklus Timer zuruecksetzen
      $timer[2]=0              ;EntnahmeTimerzuruecksetzen
      I_Zykluszaehler=0        ;Zykluszaehler zuruecksetzen
      I_Ablagezaehler=0        ;Ablagezaehler zuruecksetzen
      I_Anfahrteil=2           ;Anfahrteile für Ausschussdeklaration setzen
      B_Teilaufnahme=TRUE      ;Rueckwaerts raus deaktivieren
      B_Fangaktiv=FALSE
      
      B_BT_Kontrolle=FALSE     ;Merker fuer Teilekontrolle
      B_Reinf=FALSE            ;Merker Einfahren nach SGM_S_ROB
      B_Rueckwaerts=FALSE      ;Merker fuer Rueckwaerts rausfahren
      B_SGM_Grundstellung=FALSE;Merker fuer SGM in Grundstellung
      B_Form_zu=FALSE          ;Form geschlossen Merker zuruecksetzen
      B_Ausschuss=FALSE        ;Ausschussmerker zuruecksetzen
      
      interrupt on 20
      
      Brenner (I_n_aktive_Brenner,#init)
      Test_Grundstellung ()
      
      if (B_Beflammen_Ein==TRUE) then
         Brenner (I_n_aktive_Brenner,#set_auto)
      endif
      
      Automatik_Start ()
      
      Bewegung ()
      
      I_Antwort=0
      
      if (B_rueckwaerts==TRUE) then
         RRaus ( )
         
         B_rueckwaerts=FALSE
         
         ;FOLD DIALOGANFRAGE
            Dialog (2) 
         ;ENDFOLD
      endif
      
   until (I_Antwort<>2)
   
   ;Schwenkarme in Grundstellung
   ;Zangenarm (#setze,#GS)
   ;brennerarm (#setze,#GS)
   ;brennerarm (#pruefe,#GS)
   
END

;***************************************************
;** Ende Hauptprogramm, Anfang lokale UPs **********
;***************************************************
DEF Bewegung ()
   
   repeat
      
      SGM_Einfahren ()
      
      B_Teilaufnahme=TRUE
      if  ($mode_op==#T1) then
         halt ; bei Betriebsart T1 anhalten
      endif
      
      SGM_Entnahme ()
      
      ;Beschnitt ()
      
      Anguss_Abwerfen ()
      
      ; wait for ((E_SGM_Form_zu==TRUE) or (B_Form_zu==TRUE) or (B_GST_war_gedrueckt==TRUE))
      ; warte auf Form geschlossen oder SGM in Handbetrieb
      
      Umgreifstation() 
      
      ;if ((E_mit_Beflammen==TRUE) and (B_Ausschuss==FALSE)) then ; $IN[1202] mit Beflammen von SPS
      ; Beflammen ()
      ;else
      ;ohne_Beflammen ()
      ;endif
      
      if ((E_mit_Bedrucken==TRUE) AND (E_RFID_RECHTS OR E_RFID_LINKS)) AND (B_Ausschuss==FALSE) then ; $IN[1201] mit Bedrucken von SPS und kein Ausschussignal von SGM
         RFID() 
      else
         ohne_RFID()
      endif
      
      ;IF ( B_Ausschuss==TRUE ) then
      ;FB1_Ablage_oben ( ) ;Ablage Bad Part auf Foerderband 1 (oben)
      ;ELSE
      
      ;*************************************************
      ;****Förderband unten bei Riemenband verwenden****
      FB1_Ablage_unten ( ) ;Ablage Good Parts auf Foerderband 1 (unten)
      ;*************************************************
      
      ;ENDIF
      
      ;FOLD ZYKLISCHE ABFRAGEN
         $OV_PRO=50
         $advance=5
         I_Zykluszaehler=I_Zykluszaehler+1
         I_Anfahrteil=I_Anfahrteil+1
         
         IF  (I[1] > 900000) THEN
            I_Anfahrteil=1
         ENDIF
         
         wait for ($pro_state0==#p_active) ; SPS muss im Hintergrund laufen!
         
      ;ENDFOLD
      
   until (B_GST_war_gedrueckt==TRUE)
   
   ;Nach Grundstellungstaste oder SGM-Hand in Grundstellung fahren
   ;FOLD SPTP HOME Vel=100 % DEFAULT ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=HOME; Kuka.BlendingEnabled=FALSE; Kuka.MoveDataPtpName=DEFAULT; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XHOME WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FHOME), $BASE = SBASE(FHOME.BASE_NO), $IPO_MODE = SIPO_MODE(FHOME.IPO_FRAME), $LOAD = SLOAD(FHOME.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PDEFAULT), $APO = SAPO_PTP(PDEFAULT), $GEAR_JERK[1] = SGEAR_JERK(PDEFAULT), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0)
   ;ENDFOLD
   
   ref_u_brems()
   
END

;***************************************************
;        Einfahrbedingungen pruefen
;***************************************************

Def Einfahr ()
   
   Ventile_aus ()
   
   wait for (B_Greifergrund==TRUE) ; warte auf Greifer in GS
   wait for (E_VK1==FALSE) ; warte auf Vakuumkontrolle 1 frei
   wait for (E_VK2==FALSE) ; warte auf Vakuumkontrolle 2 frei
   wait for (E_VK3==FALSE) ; warte auf Vakuumkontrolle 3 frei
   wait for (E_VK4==FALSE) ; warte auf Vakuumkontrolle 4 frei
   
   wait for (E_ASi_22_1==TRUE); IN 361(Hub Radlauf oben li)
   wait for (E_ASi_24_1==TRUE); IN 377(Hub Radlauf unten li)
   wait for (E_ASi_26_1==TRUE); IN 393(Hub Radlauf oben re)
   wait for (E_ASi_28_1==TRUE); IN 409(Hub Radlauf unten re)
   
   while ((E_GZBG_aus==FALSE) or (E_GZBG_ein==TRUE))
      A_Bremse_auf_GZBG=TRUE
      wait sec 0.1
      A_GZBG_ein=FALSE
      A_GZBG_aus=TRUE
      wait for ((E_GZBG_aus==TRUE) and (E_GZBG_ein==FALSE))
   endwhile
   
   A_Bremse_auf_GZBG=FALSE
   wait for ((E_GZBG_aus==TRUE) and (B_Fangaktiv==FALSE))
   interrupt off 26
   interrupt on 22
   interrupt off 21
   
   while (((E_SGM_Start_IR==TRUE) and (EAv_SGM_Wkz_frei1==TRUE))==FALSE)
      wait for (E_SGM_Start_IR==TRUE) ; warte auf Form teiloffen von SGM
      wait for (EAv_SGM_Wkz_frei1==TRUE)
   endwhile
   
   B_Form_zu=FALSE     ; Merker Form geschlossen zuruecksetzen
   
   SGM_reset ()
   
   B_Ausschuss=FALSE ; Ausschussmerker zuruecksetzen
   
   IR_Ov_Pro (I_Geschw_SGM)
   
   B_Reinf=TRUE
   
end

;***************************************************
;*********** Einfahrt in SGM ***********************
;***************************************************

DEF  SGM_Einfahren ( )
   
   ;***************************************************
   ;  Unterprogramm zur Einfahrt
   ;  in die Form bis zur Teilaufnahme
   ;***************************************************
   
   $advance=5
   $flag[1]=TRUE ; Merkerflag fuer Einfahren
   B_Teilaufnahme=FALSE ; Merker Teilaufnahme zuruecksetzen
   
   if ($mode_op==#Aut) then
      continue
      wait for ((E_SGM_Form_zu==TRUE) or (B_Form_zu==TRUE)) ; $IN[2] SGM Form geschlossen (E67) od Form war zu!
   endif
   
   trigger when distance=1 delay=0 do $flag[2]=TRUE
   ;FOLD SPTP P10 CONT Vel=100 % PDAT1 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P10; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT1; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP10 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP10), $BASE = SBASE(FP10.BASE_NO), $IPO_MODE = SIPO_MODE(FP10.IPO_FRAME), $LOAD = SLOAD(FP10.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT1), $APO = SAPO_PTP(PPDAT1), $GEAR_JERK[1] = SGEAR_JERK(PPDAT1), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   trigger when distance=1 delay=0 do $flag[3]=TRUE
    trigger when distance=1 delay=0 do $flag[4]=TRUE
   ;FOLD SPTP P20 Vel=100 % PDAT2 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=False; Kuka.PointName=P20; Kuka.BlendingEnabled=False; Kuka.MoveDataPtpName=PDAT2; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=True; Kuka.ColDetectFieldEnabled=True; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=True; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP20 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP20), $BASE = SBASE(FP20.BASE_NO), $IPO_MODE = SIPO_MODE(FP20.IPO_FRAME), $LOAD = SLOAD(FP20.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT2), $APO = SAPO_PTP(PPDAT2), $GEAR_JERK[1] = SGEAR_JERK(PPDAT2), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0)
   ;ENDFOLD
   wait sec 1
   ;warte ueber der Form auf Einfahrsignal
  
   
   Einfahr ( ) ;Einfahrbedingungen pruefen
   
   ;warte auf Form ganz offen
   CONTINUE
   wait for (E_SGM_Form_auf==TRUE)
   interrupt on 21
   CONTINUE
   A_SGM_KZ1_SS=FALSE
   CONTINUE
   A_SGM_KZ1_ES=TRUE
   
   ;FOLD SPTP P30 Vel=100 % PDAT3 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P30; Kuka.BlendingEnabled=FALSE; Kuka.MoveDataPtpName=PDAT3; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP30 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP30), $BASE = SBASE(FP30.BASE_NO), $IPO_MODE = SIPO_MODE(FP30.IPO_FRAME), $LOAD = SLOAD(FP30.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT3), $APO = SAPO_PTP(PPDAT3), $GEAR_JERK[1] = SGEAR_JERK(PPDAT3), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0)
   ;ENDFOLD
   
   trigger when distance=1 delay=0 do $flag[5]=TRUE
   ;FOLD SLIN P35 CONT Vel=2 m/s CPDAT1 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P35; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT1; Kuka.VelocityPath=2; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP35 WITH $VEL = SVEL_CP(2.0, , LCPDAT1), $TOOL = STOOL2(FP35), $BASE = SBASE(FP35.BASE_NO), $IPO_MODE = SIPO_MODE(FP35.IPO_FRAME), $LOAD = SLOAD(FP35.TOOL_NO), $ACC = SACC_CP(LCPDAT1), $ORI_TYPE = SORI_TYP(LCPDAT1), $APO = SAPO(LCPDAT1), $JERK = SJERK(LCPDAT1), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   trigger when distance=1 delay=0 do A_V1_ein=TRUE
   trigger when distance=1 delay=0 do $flag[6]=TRUE
   ;FOLD SLIN P40 CONT Vel=2 m/s CPDAT2 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=False; Kuka.PointName=P40; Kuka.BlendingEnabled=True; Kuka.MoveDataName=CPDAT2; Kuka.VelocityPath=2; Kuka.VelocityFieldEnabled=True; Kuka.ColDetectFieldEnabled=True; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=True; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP40 WITH $VEL = SVEL_CP(2.0, , LCPDAT2), $TOOL = STOOL2(FP40), $BASE = SBASE(FP40.BASE_NO), $IPO_MODE = SIPO_MODE(FP40.IPO_FRAME), $LOAD = SLOAD(FP40.TOOL_NO), $ACC = SACC_CP(LCPDAT2), $ORI_TYPE = SORI_TYP(LCPDAT2), $APO = SAPO(LCPDAT2), $JERK = SJERK(LCPDAT2), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ; Aufnahme des Artikels
   ;trigger when distance=1 delay=-100 do A_V1_ein=TRUE
   ;trigger when distance=1 delay=-100 do A_V2_ein=TRUE
   ;trigger when distance=1 delay=-100 do A_V3_ein=TRUE
   ;trigger when distance=1 delay=-100 do A_V4_ein=TRUE
   
   ; Aufnahme des Artikels
   trigger when distance=1 delay=0 do $flag[7]=TRUE
   
   ;FOLD SLIN P100 Vel=1 m/s CPDAT3 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P100; Kuka.BlendingEnabled=FALSE; Kuka.MoveDataName=CPDAT3; Kuka.VelocityPath=1; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP100 WITH $VEL = SVEL_CP(1.0, , LCPDAT3), $TOOL = STOOL2(FP100), $BASE = SBASE(FP100.BASE_NO), $IPO_MODE = SIPO_MODE(FP100.IPO_FRAME), $LOAD = SLOAD(FP100.TOOL_NO), $ACC = SACC_CP(LCPDAT3), $ORI_TYPE = SORI_TYP(LCPDAT3), $APO = SAPO(LCPDAT3), $JERK = SJERK(LCPDAT3), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0)
   ;ENDFOLD
   
   ; Zylinder (Greifzangen und Sauger) zustellen
   A_BV2_GS=FALSE ;OUT 14=FALSE(Radlauf1)
   A_BV2_AS=TRUE  ;OUT 13=FALSE(Radlauf1)
   A_BV3_GS=FALSE ;OUT 16=TRUE (Radlauf2)
   A_BV3_AS=TRUE  ;OUT 15=TRUE (Radlauf2)
   
   wait sec 0.2
   
   Chk_BV(2, #AS)
   
   Wait SEC 0.5
   
   ; Teil und Anguesse Greifen
   A_BV1_GS=FALSE     ;$OUT[12]=FALSE   (Teil greifen)
   A_BV1_AS=TRUE      ;$OUT[11]=TRUE    (Teil greifen
   A_BV4_GS=FALSE     ;$OUT[18]=FALSE   (Anguesse greifen)
   A_BV4_AS=TRUE      ;$OUT[17]=TRUE    (Anguesse greifen)
   
   wait sec 0.1
   Teileabfrage()
   
   A_BV2_AS=FALSE;OUT 13=FALSE (Radlauf1)
   A_BV2_GS=TRUE  ;OUT 14=TRUE (Radlauf1)
   
   Chk_BV(2, #GS)
   
   wait sec 0.1
   Teileabfrage()
   
   ;GZBG frei schalten
   ;Überwachung aus
   interrupt off 26
   B_Fangaktiv=TRUE
   
   ;Bremse lueften & GZBG schwimmend
   
   ;KZ ausfahren & GZBG wird zurueckgedrueckt
   ;A_SGM_KZ1_SS=FALSE
   ;A_SGM_KZ1_ES=TRUE
   ;FOLD WAIT FOR ( IN 49 'SGM Kernzüge 1 in Entnahmestellung' )  ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.logics.waitfor; Kuka.WaitLogicTerm1=None; Kuka.WaitForNot1=FALSE; Kuka.WaitLogicOp2.Term1=None; Kuka.WaitForNot2.Term1=FALSE; Kuka.WaitForSysVar2.Term1=IN; Kuka.WaitForIndex2.Term1=49; Kuka.WaitForIndexName2.Term1=SGM Kernz&#252&sc/ge 1 in Entnahmestellung; Kuka.WaitForTermNumbers=1; Kuka.WaitForOpNumbers=2; Kuka.WaitForCont=FALSE
      ;ENDFOLD
      WAIT FOR  ( $IN[49] )
   ;ENDFOLD
   wait for ((E_SGM_KZ1_ES==TRUE) and (E_SGM_KZ1_SS==FALSE))
   wait sec 0.1
   
   Ausreiss ( )
   
   wait sec 0.1
   
   B_BT_Kontrolle=TRUE
   B_Teilaufnahme=TRUE
   
   $advance=5
   
END

;***************************************************
;**** Programm zum Ausfahren aus der SGM nach ******
;********** erfolgter Teileaufnahme ****************
;***************************************************

DEF SGM_Entnahme ()
   
   IR_Ov_Pro (I_Geschw_SGM)
   
   ;FOLD SLIN P100 CONT Vel=1 m/s CPDAT4 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P100; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT4; Kuka.VelocityPath=1; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP100 WITH $VEL = SVEL_CP(1.0, , LCPDAT4), $TOOL = STOOL2(FP100), $BASE = SBASE(FP100.BASE_NO), $IPO_MODE = SIPO_MODE(FP100.IPO_FRAME), $LOAD = SLOAD(FP100.TOOL_NO), $ACC = SACC_CP(LCPDAT4), $ORI_TYPE = SORI_TYP(LCPDAT4), $APO = SAPO(LCPDAT4), $JERK = SJERK(LCPDAT4), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;A_Bremse_auf_GZBG=TRUE
   ;A_GZBG_ein=TRUE
   ;A_GZBG_aus=FALSE
   ;wait sec 0.1
   ;wait for ((E_GZBG_aus==FALSE) and (E_GZBG_ein==TRUE))
   ;A_Bremse_auf_GZBG=FALSE
   
   Teileabfrage()
   
   ;FOLD SLIN P102 CONT Vel=1 m/s CPDAT5 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P102; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT5; Kuka.VelocityPath=1; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP102 WITH $VEL = SVEL_CP(1.0, , LCPDAT5), $TOOL = STOOL2(FP102), $BASE = SBASE(FP102.BASE_NO), $IPO_MODE = SIPO_MODE(FP102.IPO_FRAME), $LOAD = SLOAD(FP102.TOOL_NO), $ACC = SACC_CP(LCPDAT5), $ORI_TYPE = SORI_TYP(LCPDAT5), $APO = SAPO(LCPDAT5), $JERK = SJERK(LCPDAT5), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   Teileabfrage()
   
   ;Ueberwachung Teil & Vakuum
   ;wait for (E_VK1==TRUE)
   ;wait for (E_VK2==TRUE)
   ;Chk_BV (1,#AS)
   
   $TIMER[1]=0
   $TIMER_STOP[1]=FALSE
   trigger when distance=1 delay=0 do A_SGM_KZ1_ES=FALSE
   trigger when distance=1 delay=0 do A_SGM_KZ1_SS=TRUE
   ;FOLD SPTP P40 CONT Vel=100 % PDAT85 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=False; Kuka.PointName=P40; Kuka.BlendingEnabled=True; Kuka.MoveDataPtpName=PDAT85; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=True; Kuka.ColDetectFieldEnabled=True; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=True; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP40 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP40), $BASE = SBASE(FP40.BASE_NO), $IPO_MODE = SIPO_MODE(FP40.IPO_FRAME), $LOAD = SLOAD(FP40.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT85), $APO = SAPO_PTP(PPDAT85), $GEAR_JERK[1] = SGEAR_JERK(PPDAT85), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P35 CONT Vel=100 % PDAT84 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=False; Kuka.PointName=P35; Kuka.BlendingEnabled=True; Kuka.MoveDataPtpName=PDAT84; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=True; Kuka.ColDetectFieldEnabled=True; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=True; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP35 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP35), $BASE = SBASE(FP35.BASE_NO), $IPO_MODE = SIPO_MODE(FP35.IPO_FRAME), $LOAD = SLOAD(FP35.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT84), $APO = SAPO_PTP(PPDAT84), $GEAR_JERK[1] = SGEAR_JERK(PPDAT84), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P30 CONT Vel=100 % PDAT86 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=False; Kuka.PointName=P30; Kuka.BlendingEnabled=True; Kuka.MoveDataPtpName=PDAT86; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=True; Kuka.ColDetectFieldEnabled=True; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=True; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP30 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP30), $BASE = SBASE(FP30.BASE_NO), $IPO_MODE = SIPO_MODE(FP30.IPO_FRAME), $LOAD = SLOAD(FP30.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT86), $APO = SAPO_PTP(PPDAT86), $GEAR_JERK[1] = SGEAR_JERK(PPDAT86), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ; Start Form schliessen an SGM
   TRIGGER WHEN DISTANCE = 1 DELAY = 0 DO $Timer_Stop[2]=TRUE
   TRIGGER WHEN DISTANCE = 1 DELAY = 0 DO IR_Ov_Pro (I_Geschw_allgemein) PRIO = 1   
   trigger when distance=1 delay=0 do SGMForm_schliessen ( ) prio=-1
   ;FOLD SPTP P20 CONT Vel=100 % PDAT4 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P20; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT4; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP20 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP20), $BASE = SBASE(FP20.BASE_NO), $IPO_MODE = SIPO_MODE(FP20.IPO_FRAME), $LOAD = SLOAD(FP20.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT4), $APO = SAPO_PTP(PPDAT4), $GEAR_JERK[1] = SGEAR_JERK(PPDAT4), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   I_Entnahmezeit = $Timer[2]
   I[2]=$TIMER[2]
   
   trigger when distance=1 delay=-100 do A_BV2_GS=FALSE
   trigger when distance=1 delay=-100 do A_BV2_AS=TRUE
   trigger when distance=1 delay=-100 do A_BV3_GS=FALSE
   trigger when distance=1 delay=-100 do A_BV3_AS=TRUE
   ;FOLD SPTP P10 CONT Vel=100 % PDAT5 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P10; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT5; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP10 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP10), $BASE = SBASE(FP10.BASE_NO), $IPO_MODE = SIPO_MODE(FP10.IPO_FRAME), $LOAD = SLOAD(FP10.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT5), $APO = SAPO_PTP(PPDAT5), $GEAR_JERK[1] = SGEAR_JERK(PPDAT5), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD 
   
   ;Überwachung ein
   interrupt off 26
   B_Fangaktiv=FALSE
   
   ;FOLD SPTP P200 CONT Vel=100 % PDAT6 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P200; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT6; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP200 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP200), $BASE = SBASE(FP200.BASE_NO), $IPO_MODE = SIPO_MODE(FP200.IPO_FRAME), $LOAD = SLOAD(FP200.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT6), $APO = SAPO_PTP(PPDAT6), $GEAR_JERK[1] = SGEAR_JERK(PPDAT6), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD     
   
   ;GZBG wieder in GS bringen
   
   
   IF  (E_GZBG_aus==FALSE) or (E_GZBG_ein==TRUE)  THEN
              
         A_Bremse_auf_GZBG=TRUE
         wait sec 0.2
         A_GZBG_ein=FALSE
         A_GZBG_aus=TRUE
         
         wait for ((E_GZBG_aus==TRUE) and (E_GZBG_ein==FALSE))
         wait sec 0.2
         A_Bremse_auf_GZBG=FALSE
         
      
   ENDIF
   
END

;**************************************************
;Ablegen der Ausschuss Teile auf Foerderband 1 oben
;**************************************************

DEF FB1_Ablage_oben ()
   
   ;4 GURT RIEMENBAND IST ABLAGE UNTEN
   RETURN
   
   IR_Ov_Pro (I_Geschw_FB)
   
   ;FOLD SPTP P1900 CONT Vel=100 % PDAT7 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1900; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT7; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1900 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1900), $BASE = SBASE(FP1900.BASE_NO), $IPO_MODE = SIPO_MODE(FP1900.IPO_FRAME), $LOAD = SLOAD(FP1900.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT7), $APO = SAPO_PTP(PPDAT7), $GEAR_JERK[1] = SGEAR_JERK(PPDAT7), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD Bandlaufzeiten an SPS uebergeben
      ;continue
      ;AS_Laufzeit_FB1=R_Laufzeit_FB1*10
      ;continue
      ;AS_Nachlaufzeit_FB1=R_Nachlaufzeit_FB1*10
      ;continue
      ;AS_Laufzeit_FB2=R_Laufzeit_FB2*10
      ;continue
      ;AS_Nachlaufzeit_FB2=R_Nachlaufzeit_FB2*10
   ;ENDFOLD
   
   continue
   A_Anf_FB1_Bt_ablegen=TRUE 
   
   ; positionieren fuer Ablegen auf Band
   ;FOLD SPTP P1910 CONT Vel=100 % PDAT8 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1910; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT8; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1910 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1910), $BASE = SBASE(FP1910.BASE_NO), $IPO_MODE = SIPO_MODE(FP1910.IPO_FRAME), $LOAD = SLOAD(FP1910.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT8), $APO = SAPO_PTP(PPDAT8), $GEAR_JERK[1] = SGEAR_JERK(PPDAT8), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P1920 CONT Vel=100 % PDAT9 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1920; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT9; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1920 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1920), $BASE = SBASE(FP1920.BASE_NO), $IPO_MODE = SIPO_MODE(FP1920.IPO_FRAME), $LOAD = SLOAD(FP1920.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT9), $APO = SAPO_PTP(PPDAT9), $GEAR_JERK[1] = SGEAR_JERK(PPDAT9), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   continue
   wait for (E_FB1_oben_Ant_ber==TRUE)
   
   ;FOLD SPTP P1930 CONT Vel=100 % PDAT10 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1930; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT10; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1930 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1930), $BASE = SBASE(FP1930.BASE_NO), $IPO_MODE = SIPO_MODE(FP1930.IPO_FRAME), $LOAD = SLOAD(FP1930.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT10), $APO = SAPO_PTP(PPDAT10), $GEAR_JERK[1] = SGEAR_JERK(PPDAT10), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   continue
   A_AbFrg_FB1=FALSE
   continue
   A_Anf_FB1_Bt_ablegen=TRUE ; Anforderung Bauteil auf FB 1 ablegen
   continue
   wait for (E_FB1_oben_LS_Anf==TRUE) ;Lightguard Conveyor is NC Contact
   wait for (R_Laufzeit_FB1_o_reached==TRUE) ;is the last takt complete? 
   
   trigger when distance=1 delay=0 do B_BT_Kontrolle=FALSE
   ;FOLD SPTP P1940 CONT Vel=100 % PDAT11 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1940; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT11; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1940 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1940), $BASE = SBASE(FP1940.BASE_NO), $IPO_MODE = SIPO_MODE(FP1940.IPO_FRAME), $LOAD = SLOAD(FP1940.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT11), $APO = SAPO_PTP(PPDAT11), $GEAR_JERK[1] = SGEAR_JERK(PPDAT11), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;Ablageposition
   ;FOLD SLIN P1950 CONT Vel=0.5 m/s CPDAT9 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1950; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT9; Kuka.VelocityPath=0.5; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP1950 WITH $VEL = SVEL_CP(0.5, , LCPDAT9), $TOOL = STOOL2(FP1950), $BASE = SBASE(FP1950.BASE_NO), $IPO_MODE = SIPO_MODE(FP1950.IPO_FRAME), $LOAD = SLOAD(FP1950.TOOL_NO), $ACC = SACC_CP(LCPDAT9), $ORI_TYPE = SORI_TYP(LCPDAT9), $APO = SAPO(LCPDAT9), $JERK = SJERK(LCPDAT9), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD OUT 2 'Vakuumkreis 1 saugen' State=FALSE ;%{PE}%R 8.3.48,%MKUKATPBASIS,%COUT,%VOUTX,%P 2:2, 3:Vakuumkreis 1 saugen, 5:FALSE, 6:
      $OUT[2]=FALSE
   ;ENDFOLD
   
   ;FOLD OUT 4 'Vakuumkreis 2 saugen' State=FALSE ;%{PE}%R 8.3.48,%MKUKATPBASIS,%COUT,%VOUTX,%P 2:4, 3:Vakuumkreis 2 saugen, 5:FALSE, 6:
      $OUT[4]=FALSE
   ;ENDFOLD
   ;FOLD PULSE 1 'Vakuumkreis 1 blasen' State=TRUE Time=1 sec;%{PE}%R 8.3.48,%MKUKATPBASIS,%COUT,%VPULSE,%P 2:1, 3:Vakuumkreis 1 blasen, 5:TRUE, 6:, 8:1
      PULSE($OUT[1], TRUE,1)
   ;ENDFOLD
   
   ;FOLD PULSE 3 'Vakuumkreis 2 blasen' State=TRUE Time=1 sec;%{PE}%R 8.3.48,%MKUKATPBASIS,%COUT,%VPULSE,%P 2:3, 3:Vakuumkreis 2 blasen, 5:TRUE, 6:, 8:1
      PULSE($OUT[3], TRUE,1)
   ;ENDFOLD
   
   wait sec 0.5
   Ventile_aus ()
   wait sec 0.5
   
   ;************************************
   
   ;Waage_abnullen_abfrage ( )
   
   ;************************************
   
   A_FB1_Unten_Start=TRUE ;FB1 oben takten
   A_FB1_Oben_Start=TRUE ;FB1 oben takten
   B_Abbruch_aktiv=FALSE
   
   trigger when distance=1 delay=0 do A_Bt_abgelegt_FB1=FALSE
   trigger when distance=1 delay=0 do A_AbFrg_FB1=TRUE
   ;FOLD SLIN P1940 CONT Vel=0.5 m/s CPDAT10 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1940; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataName=CPDAT10; Kuka.VelocityPath=0.5; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SLIN
      ;ENDFOLD
      SLIN XP1940 WITH $VEL = SVEL_CP(0.5, , LCPDAT10), $TOOL = STOOL2(FP1940), $BASE = SBASE(FP1940.BASE_NO), $IPO_MODE = SIPO_MODE(FP1940.IPO_FRAME), $LOAD = SLOAD(FP1940.TOOL_NO), $ACC = SACC_CP(LCPDAT10), $ORI_TYPE = SORI_TYP(LCPDAT10), $APO = SAPO(LCPDAT10), $JERK = SJERK(LCPDAT10), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P1930 CONT Vel=100 % PDAT13 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1930; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT13; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1930 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1930), $BASE = SBASE(FP1930.BASE_NO), $IPO_MODE = SIPO_MODE(FP1930.IPO_FRAME), $LOAD = SLOAD(FP1930.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT13), $APO = SAPO_PTP(PPDAT13), $GEAR_JERK[1] = SGEAR_JERK(PPDAT13), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P1920 CONT Vel=100 % PDAT14 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1920; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT14; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
      ;ENDFOLD
      SPTP XP1920 WITH $VEL_AXIS[1] = SVEL_JOINT(100.0), $TOOL = STOOL2(FP1920), $BASE = SBASE(FP1920.BASE_NO), $IPO_MODE = SIPO_MODE(FP1920.IPO_FRAME), $LOAD = SLOAD(FP1920.TOOL_NO), $ACC_AXIS[1] = SACC_JOINT(PPDAT14), $APO = SAPO_PTP(PPDAT14), $GEAR_JERK[1] = SGEAR_JERK(PPDAT14), $COLLMON_TOL_PRO[1] = USE_CM_PRO_VALUES(0) C_Spl
   ;ENDFOLD
   
   ;FOLD SPTP P1910 CONT Vel=100 % PDAT15 Tool[1] Base[0] ;%{PE}
      ;FOLD Parameters ;%{h}
         ;Params IlfProvider=kukaroboter.basistech.inlineforms.movement.spline; Kuka.IsGlobalPoint=FALSE; Kuka.PointName=P1910; Kuka.BlendingEnabled=TRUE; Kuka.MoveDataPtpName=PDAT15; Kuka.VelocityPtp=100; Kuka.VelocityFieldEnabled=TRUE; Kuka.ColDetectFieldEnabled=TRUE; Kuka.CurrentCDSetIndex=0; Kuka.MovementParameterFieldEnabled=TRUE; IlfCommand=SPTP
